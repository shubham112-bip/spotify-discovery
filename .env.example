# Copy this file to .env and fill in values. Never commit .env.

# Spotify (Commute Compass MVP) — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# LLM — use one or both
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Airtable for review pipeline output
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
